# Dependencies
node_modules/

# WhatsApp session / auth credentials — NEVER commit these
session/*
!session/.gitkeep

# Runtime data (auto-regenerated on first run)
data/*.json
!data/.gitkeep

# User-dropped plugins (kept local, not part of the published bot)
x-system/plugin/extra/*
!x-system/plugin/extra/.gitkeep

# Env & secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/
