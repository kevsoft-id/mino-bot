# ═══════════════════════════════════════════════════════════════
#   MINO BOT ULTRA — Konfigurasi .env
#   Salin file ini menjadi .env lalu isi nilainya
#   ATAU jalankan: node setup.js  (lebih mudah!)
# ═══════════════════════════════════════════════════════════════
#   ⚠ JANGAN pernah commit file .env ke GitHub!
#   ⚠ Tambahkan .env ke .gitignore Anda.
# ═══════════════════════════════════════════════════════════════

# ── Nomor & Identitas ──────────────────────────────────────────
# Nomor WhatsApp yang dipakai bot (untuk pairing code)
# Format: kode negara + nomor, tanpa + atau spasi
# Contoh Indonesia : 6281234567890
# Contoh Malaysia  : 60123456789
BOT_NUMBER=6281234567890

# Nomor owner — pisahkan dengan koma jika lebih dari satu
# Contoh multi-owner: 6281111111111,6282222222222
OWNER_NUMBER=6281234567890

# Nama owner yang ditampilkan di menu
OWNER_NAME=KevSoft-ID

# Nama bot yang ditampilkan di chat
BOT_NAME=Mino Bot Ultra

# ── Pengaturan Bot ────────────────────────────────────────────
# Prefix perintah (karakter pemicu sebelum nama perintah)
PREFIX=.

# Mode: public = semua orang bisa pakai | self = hanya owner
MODE=public

# Zona waktu (contoh: Asia/Jakarta, Asia/Kuala_Lumpur, UTC)
TIMEZONE=Asia/Jakarta

# ── AI Gemini ─────────────────────────────────────────────────
# Dapatkan API Key GRATIS di: https://aistudio.google.com/apikey
# Kosongkan jika belum punya (fitur AI tidak aktif)
GEMINI_API_KEY=your_gemini_api_key_here

# Model yang digunakan: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Persona / kepribadian AI (opsional, bisa dikosongkan)
AI_PERSONA=Kamu adalah Mino Bot Ultra, asisten WhatsApp cerdas dan ramah oleh KevSoft-ID. Jawab dalam Bahasa Indonesia santai.

# ── Fitur Auto ────────────────────────────────────────────────
# true = aktif | false = nonaktif
AUTO_TYPING=true
AUTO_READ=true

# Auto reply semua pesan di grup dengan AI (hati-hati, bisa spam)
AUTO_AI=false

# ── Anti-Fitur ────────────────────────────────────────────────
ANTI_LINK=false
ANTI_SPAM=true

# Batas perintah per 10 detik per user (anti-spam)
SPAM_LIMIT=5

# ── Ekonomi (koin virtual) ────────────────────────────────────
DAILY_COINS=500
START_COINS=1000
WORK_MIN_COINS=50
WORK_MAX_COINS=300

# ── Sistem Limit ──────────────────────────────────────────────
# Berapa perintah maksimum per hari (direset tiap tengah malam)
LIMIT_FREE=25          # user biasa
LIMIT_PREMIUM=200      # user premium

# Bonus limit dari .claimlimit
LIMIT_CLAIM_BONUS=15

# Cooldown .claimlimit (ms) — default 6 jam = 21600000
LIMIT_CLAIM_CD=21600000

# Harga 1 paket limit (dalam koin) dan jumlah limit per paket
LIMIT_BUY_COST=100
LIMIT_BUY_AMOUNT=10

# ── Database paths (opsional, ubah jika perlu) ─────────────────
# DATABASE=./database/users.json
# GROUP_DB=./database/groups.json
# SETTINGS_DB=./database/settings.json
# OWNER_DB=./database/owners.json
# PREMIUM_DB=./database/premium.json

# ── Sistem ────────────────────────────────────────────────────
NODE_ENV=production
