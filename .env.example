# ═══════════════════════════════════════
#   MINO BOT ULTRA — Konfigurasi .env
# ═══════════════════════════════════════
# Salin file ini menjadi .env lalu isi nilainya

# ── Identitas ──
BOT_NAME=Mino Bot Ultra
OWNER_NUMBER=6281234567890
OWNER_NAME=kevsoft-id
PREFIX=.
MODE=public
TIMEZONE=Asia/Jakarta

# ── AI (WAJIB untuk fitur AI) ──
# Dapatkan key gratis di: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Persona AI (opsional)
AI_PERSONA=Kamu adalah Mino Bot Ultra, asisten WhatsApp yang cerdas dan ramah.

# ── Node ──
NODE_ENV=production
